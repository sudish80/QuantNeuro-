# =========================================
# Runtime / Host Environment Variables
# =========================================

# Environment mode: paper or live
ENVIRONMENT=paper

# Compliance / legal settings
JURISDICTION=GLOBAL
RETENTION_DAYS=365
COMPLIANCE_PROVIDER_URL=https://your-compliance-provider.example.com
COMPLIANCE_PROVIDER_API_KEY=replace_with_compliance_api_key
COMPLIANCE_DECISIONS_PATH=./output/compliance_decisions.json

# Security / KMS
KMS_KEY_ID=replace_with_kms_key_id
KMS_REGION=us-east-1
# Fallback encryption if KMS is unavailable (set a strong secret)
JOURNAL_PASSPHRASE=replace_with_long_random_passphrase
# Keep plaintext CSV journal disabled in production
TRADE_JOURNAL_PLAINTEXT_ENABLED=false

# Alerts and operations
ALERTS_WEBHOOK_URL=https://webhook.site/35729cb4-a171-4222-9295-b59eac3351ac

# Runtime state and logs
KILL_SWITCH_PATH=./kill_switch.flag
STATE_FILE=./output/runtime_state.json
TRADE_JOURNAL_PATH=./output/trade_journal.csv
ENCRYPTED_AUDIT_LOG_PATH=./output/audit_log.enc
METRICS_PATH=./output/metrics.csv

# AlphaVantage data source
ALPHAVANTAGE_BASE_URL=https://www.alphavantage.co/query
ALPHAVANTAGE_API_KEY=
ALPHAVANTAGE_RATE_LIMIT=5  # Requests per minute (free tier: 5 req/min)
ALPHAVANTAGE_TIMEOUT_SEC=30

# Risk guardrails
MAX_DAILY_LOSS_PCT=0.03
MAX_ASSET_EXPOSURE_PCT=0.20
MAX_TOTAL_EXPOSURE_PCT=0.80
CIRCUIT_BREAKER_LOSS_PCT=0.05
CIRCUIT_BREAKER_COOLDOWN_SEC=1800
